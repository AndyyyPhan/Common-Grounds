rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read any user profile
      allow read: if isSignedIn();

      // Users can only write their own profile
      allow write: if isOwner(userId);
    }

    // Waves collection
    match /waves/{waveId} {
      // Allow list queries - user can see waves where they are sender or receiver
      // Note: Individual documents are filtered by the query itself
      allow list: if isSignedIn();

      // Allow reading single document if you're the sender or receiver
      allow get: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );

      // Allow creating if you're the sender
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;

      // Allow updating if you're the receiver (to accept/decline)
      // OR if you're the sender (to cancel)
      allow update: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.senderId == request.auth.uid
      );

      // Allow deleting if you're the sender (to cancel)
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Mutual matches collection
    match /mutual_matches/{matchId} {
      // Allow list queries - user can see their matches
      // Note: Individual documents are filtered by the query itself
      allow list: if isSignedIn();

      // Allow reading single document if you're one of the matched users
      allow get: if isSignedIn() && (
        resource.data.user1Id == request.auth.uid ||
        resource.data.user2Id == request.auth.uid
      );

      // Allow creating mutual matches (automated by wave service)
      allow create: if isSignedIn() && (
        request.resource.data.user1Id == request.auth.uid ||
        request.resource.data.user2Id == request.auth.uid
      );

      // Don't allow updates or deletes for now
      allow update: if false;
      allow delete: if false;
    }

    // Conversations collection
    match /conversations/{conversationId} {
      // Allow list queries for authenticated users
      allow list: if isSignedIn();

      // Allow reading single document if you're a participant
      allow get: if isSignedIn() &&
        request.auth.uid in resource.data.participantIds;

      // Allow creating if you're one of the participants
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participantIds;

      // Allow updating if you're a participant (for marking as read, etc.)
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participantIds;

      // Allow deleting if you're a participant
      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.participantIds;

      // _counters subcollection for message sequence numbers
      match /_counters/{counterId} {
        // Allow authenticated users to read/write counters
        // The parent conversation and message creation rules already enforce participant checks
        // so we can safely allow counter access for authenticated users
        allow read, write: if isSignedIn();
      }
    }

    // Messages collection
    match /messages/{messageId} {
      // Allow list queries for authenticated users
      // The query itself filters by conversationId
      allow list: if isSignedIn();

      // Allow reading single message if you're a participant in the conversation
      allow get: if isSignedIn() &&
        exists(/databases/$(database)/documents/conversations/$(resource.data.conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds;

      // Allow creating if you're the sender and a participant in the conversation
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        exists(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participantIds;

      // Don't allow updates or deletes
      allow update: if false;
      allow delete: if false;
    }
  }
}
